{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectUnknown high-resolution building sprite manifest",
  "type": "object",
  "required": ["schemaVersion", "families"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "families": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "source", "sourceSize", "sourceSha256", "variants"],
        "properties": {
          "tool": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "sourceSize": {
            "type": "array",
            "prefixItems": [{ "type": "integer", "minimum": 1 }, { "type": "integer", "minimum": 1 }],
            "minItems": 2,
            "maxItems": 2
          },
          "sourceSha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
          "variants": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "sourceBounds", "outputCanvas", "targetBoundsTopLeft", "ppu", "pivotNormalized", "legacyReference", "output", "expectedSha256"],
              "properties": {
                "id": { "type": "string", "pattern": "^[VF][0-9]{2}$" },
                "sourceBounds": { "$ref": "#/$defs/rect" },
                "outputCanvas": { "$ref": "#/$defs/size" },
                "targetBoundsTopLeft": { "$ref": "#/$defs/rect" },
                "ppu": { "type": "number", "exclusiveMinimum": 0 },
                "pivotNormalized": {
                  "type": "array",
                  "prefixItems": [{ "type": "number", "minimum": 0, "maximum": 1 }, { "type": "number", "minimum": 0, "maximum": 1 }],
                  "minItems": 2,
                  "maxItems": 2
                },
                "legacyReference": { "type": "string", "minLength": 1 },
                "legacyFrame": { "type": "integer", "minimum": 0 },
                "output": { "type": "string", "minLength": 1 },
                "expectedSha256": { "type": "string", "pattern": "^$|^[A-Fa-f0-9]{64}$" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "size": {
      "type": "array",
      "prefixItems": [{ "type": "integer", "minimum": 1 }, { "type": "integer", "minimum": 1 }],
      "minItems": 2,
      "maxItems": 2
    },
    "rect": {
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 1 },
        { "type": "integer", "minimum": 1 }
      ],
      "minItems": 4,
      "maxItems": 4
    }
  },
  "additionalProperties": false
}

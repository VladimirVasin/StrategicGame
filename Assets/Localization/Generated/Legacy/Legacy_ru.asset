  - m_Id: 183699885936640
    m_Localized: "\u0421\u043A\u043B\u0430\u0434 \u043F\u0440\u043E\u0434\u0443\u043A\u0446\u0438\u0438
      \u0437\u0430\u043F\u043E\u043B\u043D\u0435\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268288
    m_Localized: "\u0420\u0430\u0431\u043E\u0442\u0430\u0435\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268289
    m_Localized: "\u041D\u0443\u0436\u043D\u044B \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268290
    m_Localized: "\u0421\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268291
    m_Localized: "\u041F\u0440\u043E\u0434\u0443\u043A\u0446\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268292
    m_Localized: "\u0420\u0430\u0431\u043E\u0442\u043D\u0438\u043A \u043D\u0435 \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268293
    m_Localized: "\u041D\u0430\u0437\u043D\u0430\u0447\u044C\u0442\u0435 \u0440\u0430\u0431\u043E\u0442\u043D\u0438\u043A\u0430
      \u044D\u0442\u043E\u0439 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u0438
      \u0432 \u043E\u043A\u043D\u0435 \xAB\u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u0438\xBB."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268294
    m_Localized: "\u0421\u043A\u043B\u0430\u0434 \u043F\u0440\u043E\u0434\u0443\u043A\u0446\u0438\u0438
      \u0437\u0430\u043F\u043E\u043B\u043D\u0435\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268295
    m_Localized: "\u041D\u043E\u0441\u0438\u043B\u044C\u0449\u0438\u043A\u0438 \u0434\u043E\u043B\u0436\u043D\u044B
      \u0437\u0430\u0431\u0440\u0430\u0442\u044C \u0433\u043E\u0442\u043E\u0432\u0443\u044E
      \u043F\u0440\u043E\u0434\u0443\u043A\u0446\u0438\u044E."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268296
    m_Localized: "\u041E\u0436\u0438\u0434\u0430\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268297
    m_Localized: "\u0414\u043B\u044F \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0435\u043D\u0438\u044F
      \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u0443\u0436\u043D\u043E \u0434\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
      \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u044B\u0435 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268298
    m_Localized: "\u041F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E
      \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268299
    m_Localized: "\u041C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B \u0432 \u043D\u0430\u043B\u0438\u0447\u0438\u0438,
      \u0430 \u043D\u0430 \u0441\u043A\u043B\u0430\u0434\u0435 \u043F\u0440\u043E\u0434\u0443\u043A\u0446\u0438\u0438
      \u0435\u0441\u0442\u044C \u043C\u0435\u0441\u0442\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268300
    m_Localized: "\u0412\u0445\u043E\u0434\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268301
    m_Localized: "\u0413\u043E\u0442\u043E\u0432\u0430\u044F \u043F\u0440\u043E\u0434\u0443\u043A\u0446\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268302
    m_Localized: "\u0420\u0430\u0431\u043E\u0442\u043D\u0438\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268303
    m_Localized: "\u0417\u0430\u043F\u0430\u0441\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268304
    m_Localized: "\u0421\u043A\u043B\u0430\u0434 \u0437\u0430\u043F\u043E\u043B\u043D\u0435\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268305
    m_Localized: "\u041D\u0435\u0442 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268306
    m_Localized: "\u041D\u043E\u0441\u0438\u043B\u044C\u0449\u0438\u043A\u0438 \u0434\u043E\u043B\u0436\u043D\u044B
      \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u0442\u044C \u043C\u0435\u0441\u0442\u043D\u044B\u0439
      \u0441\u043A\u043B\u0430\u0434."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268307
    m_Localized: "\u0412 \u0440\u0430\u0431\u043E\u0447\u0435\u0439 \u0437\u043E\u043D\u0435
      \u0441\u0435\u0439\u0447\u0430\u0441 \u043D\u0435\u0442 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0445
      \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268308
    m_Localized: "\u0423 \u0440\u0430\u0431\u043E\u0442\u043D\u0438\u043A\u043E\u0432
      \u0435\u0441\u0442\u044C \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0435
      \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438 \u0438 \u043C\u0435\u0441\u0442\u043E
      \u043D\u0430 \u043C\u0435\u0441\u0442\u043D\u043E\u043C \u0441\u043A\u043B\u0430\u0434\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268309
    m_Localized: "\u0421\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268310
    m_Localized: "\u041C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268311
    m_Localized: "\u041F\u0440\u043E\u0433\u0440\u0435\u0441\u0441"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268312
    m_Localized: "\u0414\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0435
      \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268313
    m_Localized: "\u041D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u044B\u0435
      \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268314
    m_Localized: "\u041C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B \u0433\u043E\u0442\u043E\u0432\u044B,
      \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u0438 \u043C\u043E\u0433\u0443\u0442
      \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u044C \u043F\u043E\u0441\u0442\u0440\u043E\u0439\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268315
    m_Localized: "\u041C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B \u0433\u043E\u0442\u043E\u0432\u044B.
      \u041D\u0430\u0437\u043D\u0430\u0447\u044C\u0442\u0435 \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u0435\u0439
      \u0432 \u043E\u043A\u043D\u0435 \xAB\u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u0438\xBB."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268316
    m_Localized: "\u0413\u043E\u0442\u043E\u0432\u043E \u043A \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268317
    m_Localized: "\u041E\u0436\u0438\u0434\u0430\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268318
    m_Localized: "\u0416\u0438\u0442\u0435\u043B\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268319
    m_Localized: "\u0414\u043E\u043C"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268320
    m_Localized: "\u0417\u0430\u043D\u044F\u0442\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268321
    m_Localized: "\u0414\u043E\u0441\u0442\u0443\u043F\u043D\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268322
    m_Localized: "\u041F\u043E\u0434 \u043A\u0440\u044B\u0448\u0435\u0439"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268323
    m_Localized: "\u0422\u0435\u043F\u043B\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268324
    m_Localized: "\u0421\u043D\u043E\u0441 \u0437\u0430\u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268325
    m_Localized: "\u0416\u0438\u0442\u0435\u043B\u0438 \u0438 \u0434\u043E\u043C\u0430\u0448\u043D\u0438\u0435
      \u0437\u0430\u043F\u0430\u0441\u044B \u0431\u0443\u0434\u0443\u0442 \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0435\u043D\u044B
      \u0431\u0435\u0437 \u043F\u043E\u0442\u0435\u0440\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268326
    m_Localized: "\u0420\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268327
    m_Localized: "\u0417\u0430\u0434\u0430\u043D\u0438\u0435"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268328
    m_Localized: "\u041D\u0435 \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268329
    m_Localized: "\u041F\u0440\u043E\u0432\u0438\u0437\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268330
    m_Localized: "\u042D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268331
    m_Localized: "\u0422\u0435\u043A\u0443\u0449\u0435\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268332
    m_Localized: "\u041F\u043B\u0430\u043D\u043E\u0432\u0430\u044F \u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268333
    m_Localized: "\u0414\u043E \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268334
    m_Localized: "\u041F\u043E\u0445\u043E\u0434\u043D\u044B\u0435 \u043F\u0430\u0439\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268335
    m_Localized: "\u0413\u043E\u0442\u043E\u0432\u043E \u043A \u0440\u0430\u0437\u0432\u0435\u0434\u043A\u0435"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268336
    m_Localized: "\u041D\u0443\u0436\u0435\u043D \u0440\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268337
    m_Localized: "\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435
      \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435 \u0440\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A\u0430
      \u0432\u044B\u0448\u0435, \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C,
      \u043E\u0442\u043E\u0437\u0432\u0430\u0442\u044C \u0438\u043B\u0438 \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
      \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u044E."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268338
    m_Localized: "\u041D\u0430\u0437\u043D\u0430\u0447\u044C\u0442\u0435 \u0441\u044E\u0434\u0430
      \u0440\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A\u0430; \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435
      \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u0438 \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u044E\u0442\u0441\u044F
      \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268339
    m_Localized: "\u041D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268340
    m_Localized: "\u041A\u0430\u0440\u0430\u0432\u0430\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268341
    m_Localized: "\u0422\u043E\u0440\u0433\u043E\u0432\u0430\u044F \u0441\u0438\u0441\u0442\u0435\u043C\u0430
      \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u043D\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268342
    m_Localized: "\u041C\u043E\u043D\u0435\u0442\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268343
    m_Localized: "\u0420\u044B\u043D\u043E\u043A"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268344
    m_Localized: "\u0410\u043A\u0442\u0438\u0432\u043D\u044B\u0435 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268345
    m_Localized: "\u0414\u043E\u0441\u0442\u0443\u043F\u043D\u043E \u0441\u0435\u0439\u0447\u0430\u0441"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268346
    m_Localized: "\u0414\u043E\u0441\u0442\u0443\u043F\u043D\u043E \u0432\u043E \u0432\u0440\u0435\u043C\u044F
      \u0442\u043E\u0440\u0433\u043E\u0432\u043B\u0438 \u0441 \u043A\u0430\u0440\u0430\u0432\u0430\u043D\u043E\u043C"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268347
    m_Localized: "\u0414\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268348
    m_Localized: "\u0421\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u0438 \u043C\u043E\u0433\u0443\u0442
      \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C \u0440\u0430\u0431\u043E\u0442\u0443
      \u0441 \u0434\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u043C\u0438
      \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u0430\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 183699936268349
    m_Localized: "\u0414\u0438\u0447\u044C"
    m_Metadata:
      m_Items: []

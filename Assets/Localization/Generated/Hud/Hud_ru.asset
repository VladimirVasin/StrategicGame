  - m_Id: 291986291707907
    m_Localized: "\u0413\u043E\u0442\u043E\u0432\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 291986291707908
    m_Localized: "\u041A\u043E\u043D\u0442\u0440\u043E\u043B\u043B\u0435\u0440\u044B
      \u0431\u043E\u044F \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 291986291707909
    m_Localized: "\u0417\u0430\u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u043E
      \u043D\u0430 \u043D\u043E\u0447\u044C \u2014 \u0436\u0434\u0451\u043C 22:00"
    m_Metadata:
      m_Items: []
  - m_Id: 291986291707910
    m_Localized: "\u041D\u0435\u0442 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u0433\u043E
      \u0432\u0437\u0440\u043E\u0441\u043B\u043E\u0433\u043E \u0436\u0438\u0442\u0435\u043B\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 291986291707911
    m_Localized: "\u041D\u0435 \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C

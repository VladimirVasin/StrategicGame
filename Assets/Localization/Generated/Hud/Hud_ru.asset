      - rid: 465534772507312174
  - m_Id: 183705074290689
    m_Localized: "\u041E\u0431\u0435\u0441\u043F\u0435\u0447\u044C\u0442\u0435 \u0436\u0438\u0442\u0435\u043B\u0435\u0439
      \u0436\u0438\u043B\u044C\u0451\u043C, \u043F\u0440\u0435\u0436\u0434\u0435
      \u0447\u0435\u043C \u0440\u0430\u0441\u0448\u0438\u0440\u044F\u0442\u044C \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290690
    m_Localized: "\u041F\u043E\u0441\u0442\u0440\u043E\u0439\u0442\u0435 \u043B\u0430\u0433\u0435\u0440\u044C
      \u0441\u043E\u0431\u0438\u0440\u0430\u0442\u0435\u043B\u0435\u0439"
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290691
    m_Localized: "\u041F\u0435\u0440\u0435\u043D\u0435\u0441\u0438\u0442\u0435 \u0441\u0431\u043E\u0440
      \u0434\u0438\u043A\u043E\u0440\u0430\u0441\u0442\u0443\u0449\u0435\u0439 \u0435\u0434\u044B
      \u0438\u0437 \u0434\u043E\u043C\u043E\u0432 \u0432 \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u0439
      \u043B\u0430\u0433\u0435\u0440\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290692
    m_Localized: "\u041F\u043E\u0441\u0442\u0440\u043E\u0439\u0442\u0435 \u043B\u0430\u0433\u0435\u0440\u044C
      \u043B\u0435\u0441\u043E\u0440\u0443\u0431\u043E\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290693
    m_Localized: "\u041F\u043E\u0441\u0442\u0440\u043E\u0439\u0442\u0435 \u043B\u0430\u0433\u0435\u0440\u044C
      \u043A\u0430\u043C\u0435\u043D\u043E\u0442\u0451\u0441\u043E\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290694
    m_Localized: "\u041F\u043E\u0441\u0442\u0440\u043E\u0439\u0442\u0435 \u043F\u043E\u0441\u0442
      \u0440\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A\u043E\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290695
    m_Localized: "\u0421\u043E\u0437\u0434\u0430\u0439\u0442\u0435 \u0431\u0430\u0437\u0443
      \u0434\u043B\u044F \u043F\u0435\u0440\u0432\u043E\u0439 \u0440\u0430\u0437\u0432\u0435\u0434\u044B\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439
      \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0438 \u043F\u043E\u0441\u0435\u043B\u0435\u043D\u0438\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290696
    m_Localized: "\u041F\u043E\u0441\u0442\u0440\u043E\u0439\u0442\u0435 \u0441\u043A\u043B\u0430\u0434\u0441\u043A\u043E\u0439
      \u0434\u0432\u043E\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290697
    m_Localized: "\u041F\u0435\u0440\u0435\u043D\u0435\u0441\u0438\u0442\u0435 \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
      \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B \u0438\u0437 \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
      \u043A\u0430\u0440\u0430\u0432\u0430\u043D\u043D\u043E\u0439 \u043F\u043E\u0432\u043E\u0437\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290698
    m_Localized: "\u041F\u043E\u0441\u0442\u0440\u043E\u0439\u0442\u0435 \u0430\u043C\u0431\u0430\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290699
    m_Localized: "\u0421\u043E\u0431\u0435\u0440\u0438\u0442\u0435 \u0437\u0430\u043F\u0430\u0441\u044B
      \u0435\u0434\u044B \u0432 \u043E\u0434\u043D\u043E\u043C \u043C\u0435\u0441\u0442\u0435
      \u0434\u043E \u043F\u0435\u0440\u0432\u043E\u0439 \u0437\u0438\u043C\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290700
    m_Localized: "\u0417\u0430\u043F\u0430\u0441\u0438\u0442\u0435 \u0435\u0434\u0443
      \u043D\u0430 {0} \u0441\u0443\u0442\u043E\u043A"
    m_Metadata:
      m_Items:
      - rid: 465534772507312174
  - m_Id: 183705074290701
    m_Localized: "\u0421\u0435\u043C\u044C\u044F\u043C \u043D\u0443\u0436\u043D\u044B
      \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u044B\u0435 \u0437\u0430\u043F\u0430\u0441\u044B,
      \u0447\u0442\u043E\u0431\u044B \u043F\u0435\u0440\u0435\u0436\u0438\u0442\u044C
      \u043F\u0435\u0440\u0432\u0443\u044E \u0437\u0438\u043C\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290702
    m_Localized: "\u0417\u0430\u043F\u0430\u0441\u0438\u0442\u0435 \u0434\u0440\u043E\u0432\u0430
      \u043D\u0430 {0} \u0441\u0443\u0442\u043E\u043A"
    m_Metadata:
      m_Items:
      - rid: 465534772507312174
  - m_Id: 183705074290703
    m_Localized: "\u0417\u0438\u043C\u043E\u0439 \u043E\u0431\u0438\u0442\u0430\u0435\u043C\u044B\u0435
      \u0434\u043E\u043C\u0430 \u0440\u0430\u0441\u0445\u043E\u0434\u0443\u044E\u0442
      \u0434\u0440\u043E\u0432\u0430 \u043F\u043E \u043D\u043E\u0447\u0430\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290704
    m_Localized: "\u041F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u044C\u0442\u0435\u0441\u044C
      \u043A \u043F\u0435\u0440\u0432\u043E\u0439 \u0437\u0438\u043C\u0435"
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290705
    m_Localized: "{0:0.#} / {1:0} \u0434\u043D."
    m_Metadata:
      m_Items:
      - rid: 465534772507312174
  - m_Id: 183705074290706
    m_Localized: "\u041F\u0435\u0440\u0435\u0436\u0438\u0432\u0438\u0442\u0435 \u043F\u0435\u0440\u0432\u0443\u044E
      \u0437\u0438\u043C\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290707
    m_Localized: "\u0421\u043B\u0435\u0434\u0438\u0442\u0435 \u0437\u0430 \u0435\u0434\u043E\u0439,
      \u0434\u0440\u043E\u0432\u0430\u043C\u0438 \u0438 \u0436\u0438\u043B\u044C\u0451\u043C
      \u0434\u043E \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
      \u043B\u0435\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290708
    m_Localized: "\u041D\u0430\u0447\u0430\u043B\u0430\u0441\u044C \u043F\u0435\u0440\u0432\u0430\u044F
      \u0437\u0438\u043C\u0430. \u041F\u043E\u0441\u0435\u043B\u0435\u043D\u0438\u0435
      \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290709
    m_Localized: "\u041D\u0430\u0447\u0430\u043B\u0430\u0441\u044C \u043F\u0435\u0440\u0432\u0430\u044F
      \u0437\u0438\u043C\u0430. \u0417\u0430\u043F\u0430\u0441\u043E\u0432 \u043D\u0435
      \u0445\u0432\u0430\u0442\u0430\u0435\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290710
    m_Localized: "\u041F\u0435\u0440\u0432\u0430\u044F \u0437\u0438\u043C\u0430 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B\u0430\u0441\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290711
    m_Localized: "\u041E\u0442\u043A\u0440\u044B\u0442\u044C \u0441\u043F\u0438\u0441\u043E\u043A
      \u0436\u0438\u0442\u0435\u043B\u0435\u0439: \u0432\u0437\u0440\u043E\u0441\u043B\u044B\u0435,
      \u0434\u0435\u0442\u0438, \u0441\u0435\u043C\u044C\u0438 \u0438 \u0442\u0435\u043A\u0443\u0449\u0430\u044F
      \u0440\u0430\u0431\u043E\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 183705074290712
    m_Localized: "\u041D\u0430\u0441\u0435\u043B\u0435\u043D\u0438\u0435 {0}\n\u0412\u0437\u0440\u043E\u0441\u043B\u044B\u0445:

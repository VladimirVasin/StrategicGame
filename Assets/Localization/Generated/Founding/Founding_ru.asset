  m_TableData:
  - m_Id: 183706273861632
    m_Localized: "\u041F\u041E\u0421\u041B\u0415\u0414\u041D\u042F\u042F \u041D\u041E\u0427\u042C"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193280
    m_Localized: "\u041C\u044B \u0443\u0448\u043B\u0438 \u0434\u043E \u0440\u0430\u0441\u0441\u0432\u0435\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193281
    m_Localized: "\u0412\u043E\u0439\u043D\u0430 \u043D\u0430\u0441\u0442\u0438\u0433\u043B\u0430
      \u0432\u0441\u0435 \u0434\u043E\u0440\u043E\u0433\u0438 \u043F\u043E\u0437\u0430\u0434\u0438
      \u043D\u0430\u0441. \u041C\u044B \u0432\u0437\u044F\u043B\u0438 \u043B\u0438\u0448\u044C
      \u0442\u043E, \u0447\u0442\u043E \u043F\u043E\u043C\u0435\u0441\u0442\u0438\u043B\u043E\u0441\u044C
      \u0432 \u043F\u043E\u0432\u043E\u0437\u043A\u0443, \u0438 \u043F\u043E\u043E\u0431\u0435\u0449\u0430\u043B\u0438
      \u0434\u0435\u0442\u044F\u043C \u043D\u0430\u0439\u0442\u0438 \u043C\u0435\u0441\u0442\u043E,
      \u043A\u0443\u0434\u0430 \u043E\u043D\u0430 \u043D\u0435 \u0434\u043E\u0431\u0435\u0440\u0451\u0442\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193282
    m_Localized: "\u0414\u041E\u041B\u0413\u0418\u0419 \u041F\u0423\u0422\u042C"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193283
    m_Localized: "\u0414\u043E\u0440\u043E\u0433\u0430 \u043F\u043E\u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u0430
      \u043E\u0442 \u043D\u0430\u0441 \u0432\u0441\u0435\u0433\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193284
    m_Localized: "\u041D\u0435\u0434\u0435\u043B\u0438 \u0448\u043B\u0438 \u043F\u043E\u0434
      \u0434\u043E\u0436\u0434\u0451\u043C \u0441\u0440\u0435\u0434\u0438 \u0445\u043E\u043B\u043E\u0434\u043D\u044B\u0445
      \u0441\u043A\u0430\u043B. \u041C\u044B \u0432\u043C\u0435\u0441\u0442\u0435
      \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u043B\u0438 \u0433\u043E\u0440\u043D\u044B\u0435
      \u0442\u0440\u043E\u043F\u044B, \u043D\u0435 \u0441\u043B\u0435\u0434\u0443\u044F
      \u043D\u0438 \u0437\u0430 \u0447\u044C\u0438\u043C \u0437\u043D\u0430\u043C\u0435\u043D\u0435\u043C
      \u0438 \u043D\u0435 \u0441\u043B\u0443\u0436\u0430 \u043D\u0438 \u043E\u0434\u043D\u043E\u043C\u0443
      \u0433\u043E\u0441\u043F\u043E\u0434\u0438\u043D\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193285
    m_Localized: "\u0422\u0418\u0425\u0410\u042F \u0414\u041E\u041B\u0418\u041D\u0410"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193286
    m_Localized: "\u041D\u0430\u043A\u043E\u043D\u0435\u0446 \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442
      \u0437\u0430\u0442\u0438\u0445."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193287
    m_Localized: "\u041D\u0438 \u0434\u044B\u043C\u0430, \u043D\u0438 \u043C\u0430\u0440\u0448\u0438\u0440\u0443\u044E\u0449\u0438\u0445
      \u043A\u043E\u043B\u043E\u043D\u043D. \u0422\u043E\u043B\u044C\u043A\u043E
      \u0432\u043E\u0434\u0430, \u043B\u0435\u0441 \u0438 \u043F\u0440\u043E\u0441\u0442\u043E\u0440.
      \u0412\u043F\u0435\u0440\u0432\u044B\u0435 \u0434\u043E\u0440\u043E\u0433\u0430
      \u0432\u043F\u0435\u0440\u0435\u0434\u0438 \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u043B\u0430
      \u043D\u0430\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193288
    m_Localized: "\u041F\u0415\u0420\u0412\u041E\u0415 \u0420\u0415\u0428\u0415\u041D\u0418\u0415"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193289
    m_Localized: "\u0411\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u044C
      \u0431\u044B\u043B\u0430 \u043B\u0438\u0448\u044C \u043D\u0430\u0447\u0430\u043B\u043E\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193290
    m_Localized: "\u041F\u0440\u0435\u0436\u0434\u0435 \u0447\u0435\u043C \u0440\u0430\u0437\u0433\u0440\u0443\u0436\u0430\u0442\u044C
      \u043F\u043E\u0432\u043E\u0437\u043A\u0443, \u0441\u0435\u043C\u044C\u0438
      \u0441\u043E\u0431\u0440\u0430\u043B\u0438\u0441\u044C \u043D\u0430\u0434 \u043A\u0430\u0440\u0442\u043E\u0439.
      \u041E\u0442 \u043C\u0435\u0441\u0442\u0430 \u043D\u0430\u0448\u0435\u0439
      \u0441\u0435\u0433\u043E\u0434\u043D\u044F\u0448\u043D\u0435\u0439 \u0441\u0442\u043E\u044F\u043D\u043A\u0438
      \u0431\u0443\u0434\u0435\u0442 \u0437\u0430\u0432\u0438\u0441\u0435\u0442\u044C
      \u043A\u0430\u0436\u0434\u0430\u044F \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0430\u044F
      \u0437\u0438\u043C\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193291
    m_Localized: "\u041A \u043A\u0430\u043A\u043E\u043C\u0443 \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440\u0443
      \u0448\u043B\u0438 \u0440\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A\u0438?"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193292
    m_Localized: "\u0412\u043E\u0434\u0430 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442
      \u043F\u0443\u0442\u0438, \u043F\u0440\u043E\u043F\u0438\u0442\u0430\u043D\u0438\u0435
      \u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u0434\u043E\u0440\u043E\u0433\u0438
      \u0447\u0435\u0440\u0435\u0437 \u0434\u043E\u043B\u0438\u043D\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193293
    m_Localized: "\u0411\u044B\u0441\u0442\u0440\u0430\u044F \u0440\u0435\u043A\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193294
    m_Localized: "\u0411\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u0430\u044F \u0437\u0435\u043C\u043B\u044F
      \u043D\u0435\u043F\u043E\u0434\u0430\u043B\u0451\u043A\u0443 \u043E\u0442 \u0440\u0435\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193295
    m_Localized: "\u0422\u0438\u0445\u043E\u0435 \u043E\u0437\u0435\u0440\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193296
    m_Localized: "\u0417\u0430\u0449\u0438\u0449\u0451\u043D\u043D\u044B\u0439 \u0432\u043E\u0434\u043E\u0451\u043C
      \u0438 \u0443\u0434\u043E\u0431\u043D\u043E\u0435 \u043C\u0435\u0441\u0442\u043E
      \u0434\u043B\u044F \u0440\u044B\u0431\u043D\u043E\u0439 \u043B\u043E\u0432\u043B\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193297
    m_Localized: "\u0421\u0443\u0445\u0430\u044F \u0432\u043E\u0437\u0432\u044B\u0448\u0435\u043D\u043D\u043E\u0441\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193298
    m_Localized: "\u041F\u043E\u0434\u0430\u043B\u044C\u0448\u0435 \u043E\u0442 \u0431\u0435\u0440\u0435\u0433\u043E\u0432
      \u0438 \u043F\u0430\u0432\u043E\u0434\u043A\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193299
    m_Localized: "\u041A\u0430\u043A\u043E\u0435 \u0443\u043A\u0440\u044B\u0442\u0438\u0435
      \u043E\u043D\u0438 \u0438\u0441\u043A\u0430\u043B\u0438?"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193300
    m_Localized: "\u0417\u0435\u043C\u043B\u044F \u0432\u043E\u043A\u0440\u0443\u0433
      \u043B\u0430\u0433\u0435\u0440\u044F \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442
      \u043E\u0431\u0437\u043E\u0440 \u0438 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
      \u0434\u043B\u044F \u0440\u043E\u0441\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193301
    m_Localized: "\u041E\u043F\u0443\u0448\u043A\u0430 \u043B\u0435\u0441\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193302
    m_Localized: "\u0414\u0440\u0435\u0432\u0435\u0441\u0438\u043D\u0430 \u0438 \u0443\u043A\u0440\u044B\u0442\u0438\u0435
      \u0440\u044F\u0434\u043E\u043C \u0441 \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0439
      \u0437\u0435\u043C\u043B\u0451\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193303
    m_Localized: "\u041E\u0442\u043A\u0440\u044B\u0442\u044B\u0439 \u043B\u0443\u0433"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193304
    m_Localized: "\u0425\u043E\u0440\u043E\u0448\u0438\u0439 \u043E\u0431\u0437\u043E\u0440
      \u0438 \u0443\u0434\u043E\u0431\u043D\u043E\u0435 \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193305
    m_Localized: "\u041F\u043E\u043D\u0435\u043C\u043D\u043E\u0433\u0443 \u0442\u043E\u0433\u043E
      \u0438 \u0434\u0440\u0443\u0433\u043E\u0433\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193306
    m_Localized: "\u0420\u0430\u0437\u043D\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u0430\u044F
      \u043C\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C \u0431\u0435\u0437 \u044F\u0432\u043D\u043E\u0433\u043E
      \u043F\u0440\u0435\u043E\u0431\u043B\u0430\u0434\u0430\u043D\u0438\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193307
    m_Localized: "\u0427\u0442\u043E \u043F\u0440\u043E\u043A\u043E\u0440\u043C\u0438\u0442
      \u043D\u0430\u0441 \u043F\u0435\u0440\u0432\u043E\u0439 \u0437\u0438\u043C\u043E\u0439?"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193308
    m_Localized: "\u0420\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A\u0438 \u043E\u0442\u043C\u0435\u0442\u0438\u043B\u0438
      \u043C\u0435\u0441\u0442\u0430, \u043B\u0443\u0447\u0448\u0435 \u0432\u0441\u0435\u0433\u043E
      \u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0449\u0438\u0435 \u0434\u043B\u044F
      \u043F\u0435\u0440\u0432\u043E\u0433\u043E \u043F\u0440\u043E\u043C\u044B\u0441\u043B\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193309
    m_Localized: "\u0417\u0432\u0435\u0440\u0438\u043D\u044B\u0435 \u0442\u0440\u043E\u043F\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193310
    m_Localized: "\u041B\u0443\u0433\u0430 \u0438 \u043E\u043F\u0443\u0448\u043A\u0438,
      \u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0449\u0438\u0435 \u0434\u043B\u044F
      \u043E\u0445\u043E\u0442\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193311
    m_Localized: "\u0420\u044B\u0431\u043D\u044B\u0435 \u043C\u0435\u0441\u0442\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193312
    m_Localized: "\u0414\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0439 \u0432\u043E\u0434\u043E\u0451\u043C
      \u0441 \u0445\u043E\u0440\u043E\u0448\u0438\u043C\u0438 \u043C\u0435\u0441\u0442\u0430\u043C\u0438
      \u0434\u043B\u044F \u0440\u044B\u0431\u0430\u043B\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193313
    m_Localized: "\u0414\u0430\u0440\u044B \u043F\u0440\u0438\u0440\u043E\u0434\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193314
    m_Localized: "\u041B\u0435\u0441 \u0438 \u043B\u0443\u0433\u0430, \u0431\u043E\u0433\u0430\u0442\u044B\u0435
      \u0434\u0438\u043A\u043E\u0440\u043E\u0441\u0430\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193315
    m_Localized: "\u0427\u0442\u043E \u0432\u0430\u0436\u043D\u0435\u0435 \u0432\u0441\u0435\u0433\u043E
      \u043D\u0430 \u043C\u0435\u0441\u0442\u0435 \u0441\u0442\u043E\u044F\u043D\u043A\u0438?"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193316
    m_Localized: "\u041B\u044E\u0431\u043E\u0435 \u043C\u0435\u0441\u0442\u043E \u0431\u0443\u0434\u0435\u0442
      \u043F\u0440\u0438\u0433\u043E\u0434\u043D\u043E \u0434\u043B\u044F \u0436\u0438\u0437\u043D\u0438;
      \u044D\u0442\u043E\u0442 \u0432\u044B\u0431\u043E\u0440 \u0440\u0435\u0448\u0438\u0442
      \u0441\u043F\u043E\u0440 \u043C\u0435\u0436\u0434\u0443 \u0440\u0430\u0432\u043D\u043E\u0446\u0435\u043D\u043D\u044B\u043C\u0438
      \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u0430\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193317
    m_Localized: "\u041C\u0435\u0441\u0442\u043E \u0434\u043B\u044F \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193318
    m_Localized: "\u041F\u0440\u0435\u0434\u043F\u043E\u0447\u0435\u0441\u0442\u044C
      \u043E\u0442\u043A\u0440\u044B\u0442\u0443\u044E \u0437\u0435\u043C\u043B\u044E,
      \u043F\u0440\u0438\u0433\u043E\u0434\u043D\u0443\u044E \u0434\u043B\u044F \u0437\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193319
    m_Localized: "\u0420\u0435\u0441\u0443\u0440\u0441\u044B \u043F\u043E\u0431\u043B\u0438\u0437\u043E\u0441\u0442\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193320
    m_Localized: "\u041F\u0440\u0435\u0434\u043F\u043E\u0447\u0435\u0441\u0442\u044C
      \u0440\u0430\u0437\u043D\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u0443\u044E
      \u043C\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C \u0441 \u0431\u043E\u0433\u0430\u0442\u044B\u043C\u0438
      \u0440\u0435\u0441\u0443\u0440\u0441\u0430\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193321
    m_Localized: "\u0421\u0431\u0430\u043B\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0435
      \u043D\u0430\u0447\u0430\u043B\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 183706324193322
    m_Localized: "\u0421\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435

  m_TableData:
  - m_Id: 183700712214528
    m_Localized: "\u041F\u0415\u0420\u0412\u042B\u0415 \u0421\u0423\u041C\u0415\u0420\u041A\u0418"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323392
    m_Localized: "\u041F\u043E\u0434 \u043C\u0435\u0448\u043A\u0430\u043C\u0438 \u043A\u0442\u043E-\u0442\u043E
      \u0448\u0443\u0440\u0448\u0430\u043B."
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323393
    m_Localized: "\u0421\u043F\u0435\u0440\u0432\u0430 \u0438\u0437-\u043F\u043E\u0434
      \u043C\u0435\u0448\u043A\u043E\u0432 \u0434\u043E\u043D\u043E\u0441\u0438\u043B\u0441\u044F
      \u0435\u0434\u0432\u0430 \u0441\u043B\u044B\u0448\u043D\u044B\u0439 \u0448\u043E\u0440\u043E\u0445.
      \u041F\u043E\u0442\u043E\u043C \u043C\u0435\u0436\u0434\u0443 \u044F\u0449\u0438\u043A\u0430\u043C\u0438
      \u043C\u0435\u043B\u044C\u043A\u043D\u0443\u043B\u0430 \u0441\u0435\u0440\u0430\u044F
      \u0442\u0435\u043D\u044C \u2014 \u0441\u043B\u0435\u0434\u043E\u043C \u0432
      \u0442\u0435\u043C\u043D\u043E\u0442\u0443 \u044E\u0440\u043A\u043D\u0443\u043B\u0430
      \u0434\u0440\u0443\u0433\u0430\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323394
    m_Localized: "\u041F\u041E\u041B\u0423\u041D\u041E\u0427\u041D\u042B\u0419 \u041F\u0418\u0420"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323395
    m_Localized: "\u041A\u0440\u043E\u0445\u043E\u0442\u043D\u044B\u0435 \u0437\u0443\u0431\u044B
      \u0434\u043E\u0431\u0440\u0430\u043B\u0438\u0441\u044C \u0434\u043E \u043F\u0440\u0438\u043F\u0430\u0441\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323396
    m_Localized: "\u041A\u043E\u0433\u0434\u0430 \u0432\u0437\u043E\u0448\u043B\u0430
      \u043B\u0443\u043D\u0430, \u043C\u044B\u0448\u0438 \u0431\u044B\u043B\u0438
      \u0443\u0436\u0435 \u043F\u043E\u0432\u0441\u044E\u0434\u0443: \u0433\u0440\u044B\u0437\u043B\u0438
      \u0437\u0435\u0440\u043D\u043E, \u0445\u043E\u0437\u044F\u0439\u043D\u0438\u0447\u0430\u043B\u0438
      \u0432 \u043A\u043E\u0440\u0437\u0438\u043D\u0430\u0445 \u0438 \u043F\u0438\u0440\u043E\u0432\u0430\u043B\u0438
      \u043D\u0430\u0448\u0438\u043C \u043F\u0435\u0440\u0432\u044B\u043C \u0443\u0440\u043E\u0436\u0430\u0435\u043C
      \u2014 \u0431\u0443\u0434\u0442\u043E \u0434\u043B\u044F \u043D\u0438\u0445
      \u0435\u0433\u043E \u0438 \u0441\u043E\u0431\u0438\u0440\u0430\u043B\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323397
    m_Localized: "\u0422\u0418\u0425\u0418\u0415 \u041E\u0425\u041E\u0422\u041D\u0418\u041A\u0418"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323398
    m_Localized: "\u0423 \u043A\u043E\u0441\u0442\u0440\u0430 \u0432\u0434\u0440\u0443\u0433
      \u0431\u043B\u0435\u0441\u043D\u0443\u043B\u0438 \u0437\u0435\u043B\u0451\u043D\u044B\u0435
      \u0433\u043B\u0430\u0437\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323399
    m_Localized: "\u0423 \u043A\u043E\u0441\u0442\u0440\u0430 \u0431\u0435\u0441\u0448\u0443\u043C\u043D\u043E
      \u043F\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C \u043F\u043E\u0434\u0436\u0430\u0440\u0430\u044F
      \u043A\u043E\u0448\u043A\u0430 \u2014 \u0441 \u0442\u0430\u043A\u0438\u043C
      \u0432\u0438\u0434\u043E\u043C, \u0441\u043B\u043E\u0432\u043D\u043E \u0432\u0441\u0435\u0433\u0434\u0430
      \u0437\u0434\u0435\u0441\u044C \u0436\u0438\u043B\u0430. \u041C\u044B\u0448\u0438
      \u0434\u043E\u0431\u0440\u0430\u043B\u0438\u0441\u044C \u0434\u043E \u043D\u0430\u0448\u0438\u0445
      \u0437\u0430\u043F\u0430\u0441\u043E\u0432, \u0437\u0430\u0442\u043E \u0441\u043B\u0435\u0434\u043E\u043C
      \u0437\u0430 \u043D\u0438\u043C\u0438 \u043A \u043D\u0430\u043C \u043F\u0440\u0438\u0448\u043B\u0438
      \u0438 \u043E\u0445\u043E\u0442\u043D\u0438\u043A\u0438. \u0422\u0435\u043F\u0435\u0440\u044C
      \u043C\u044B \u043D\u0435 \u043F\u0440\u043E\u043F\u0430\u0434\u0451\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323400
    m_Localized: "\u0413\u043E\u0440\u0430 \u0445\u043B\u0430\u043C\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323401
    m_Localized: "\u0420\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A \u043D\u0430\u0442\u043A\u043D\u0443\u043B\u0441\u044F
      \u043D\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u0443\u044E \u0441\u0432\u0430\u043B\u043A\u0443.
      \u041F\u043E\u0440\u044B\u0442\u044C\u0441\u044F \u0441\u0440\u0435\u0434\u0438
      \u0445\u043B\u0430\u043C\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323402
    m_Localized: "\u041F\u043E\u0440\u044B\u0442\u044C\u0441\u044F \u0432 \u0445\u043B\u0430\u043C\u0435"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323403
    m_Localized: "\u041F\u0440\u043E\u0439\u0442\u0438 \u043C\u0438\u043C\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323404
    m_Localized: "\u0421\u0440\u0435\u0434\u0438 \u0445\u043B\u0430\u043C\u0430 \u043D\u0430\u0448\u043B\u0430\u0441\u044C
      \u0434\u044B\u0440\u044F\u0432\u0430\u044F \u043B\u043E\u0436\u043A\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323405
    m_Localized: "\u041F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
      \u043C\u0435\u0441\u0442\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323406
    m_Localized: "\u0412\u0415\u0421\u0422\u0418 \u041E\u0422 \u0420\u0410\u0417\u0412\u0415\u0414\u0427\u0418\u041A\u0410"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323407
    m_Localized: "\u041F\u041E\u041D\u042F\u0422\u041D\u041E"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323408
    m_Localized: "\u0414\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 183700779323409
    m_Localized: "\u041D\u0435\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 1102565969383424
    m_Localized: "\u0420\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A: {0}\n\u041E\u0440\u0438\u0435\u043D\u0442\u0438\u0440:
      {1}\n\n{2}"
    m_Metadata:
      m_Items:
      - rid: 465534841419202560
  - m_Id: 1102566015520768
    m_Localized: "\u041D\u0430\u0439\u0434\u0435\u043D \u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0439
      \u043F\u043B\u0430\u0441\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 1102566015520769
    m_Localized: "\u041F\u043E\u0431\u043B\u0438\u0437\u043E\u0441\u0442\u0438 \u0437\u0430\u043B\u0435\u0433\u0430\u0435\u0442
      \u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0439 \u043F\u043B\u0430\u0441\u0442.\n\n\u041D\u0430\u0434
      \u0437\u0430\u043B\u0435\u0436\u044C\u044E \u043C\u043E\u0436\u043D\u043E \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C
      \u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0439 \u0440\u0430\u0437\u0440\u0435\u0437."
    m_Metadata:
      m_Items: []
  - m_Id: 1102566015520770
    m_Localized: "\u041D\u0430\u0439\u0434\u0435\u043D\u0430 \u0436\u0435\u043B\u0435\u0437\u043D\u0430\u044F
      \u0436\u0438\u043B\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 1102566015520771
    m_Localized: "\u041F\u043E\u0431\u043B\u0438\u0437\u043E\u0441\u0442\u0438 \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u0442
      \u0436\u0435\u043B\u0435\u0437\u043D\u0430\u044F \u0436\u0438\u043B\u0430.\n\n\u041D\u0430\u0434
      \u0437\u0430\u043B\u0435\u0436\u044C\u044E \u043C\u043E\u0436\u043D\u043E \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C
      \u0448\u0430\u0445\u0442\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 1102566015520772
    m_Localized: "\u041C\u0435\u0441\u0442\u043E \u043E\u0441\u043C\u043E\u0442\u0440\u0435\u043D\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 1102566015520773
    m_Localized: "\u041D\u0438 \u0440\u0443\u0434\u044B, \u043D\u0438 \u0443\u0433\u043B\u044F
      \u043F\u043E\u0431\u043B\u0438\u0437\u043E\u0441\u0442\u0438 \u043D\u0435 \u043D\u0430\u0448\u043B\u043E\u0441\u044C."
    m_Metadata:
      m_Items: []

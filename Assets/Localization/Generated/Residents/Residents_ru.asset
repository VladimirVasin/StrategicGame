  - m_Id: 183701936951399
    m_Localized: "\u041F\u041E\u0421\u0422 \u0420\u0410\u0417\u0412\u0415\u0414\u0427\u0418\u041A\u041E\u0412 
      /  \u042D\u041A\u0421\u041F\u0415\u0414\u0418\u0426\u0418\u0418"
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951400
    m_Localized: "\u0417\u0410\u0427\u0415\u041C \u041D\u0423\u0416\u0415\u041D \u042D\u0422\u041E\u0422
      \u041F\u0423\u0422\u042C"
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951401
    m_Localized: "\u0420\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A\u0438 \u0438\u0434\u0443\u0442
      \u0434\u043D\u0451\u043C \u0438 \u043D\u043E\u0447\u044C\u044E, \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u044E\u0442
      \u043D\u0435\u0438\u0437\u0432\u0435\u0434\u0430\u043D\u043D\u044B\u0435 \u0437\u0435\u043C\u043B\u0438,
      \u0438\u0437\u0443\u0447\u0430\u044E\u0442 \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440\u044B
      \u0438 \u0441\u043E\u043E\u0431\u0449\u0430\u044E\u0442 \u043E \u0434\u0430\u043B\u0451\u043A\u0438\u0445
      \u0437\u0430\u043B\u0435\u0436\u0430\u0445 \u0436\u0435\u043B\u0435\u0437\u0430
      \u0438 \u0443\u0433\u043B\u044F \u2014 \u0438 \u043E\u0431\u043E \u0432\u0441\u0451\u043C
      \u043F\u0440\u043E\u0447\u0435\u043C, \u0447\u0442\u043E \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442
      \u0442\u0443\u043C\u0430\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951402
    m_Localized: "\u041E\u0414\u0418\u041D \u041F\u041E\u0421\u0422  /  \u041E\u0414\u0418\u041D
      \u0420\u0410\u0417\u0412\u0415\u0414\u0427\u0418\u041A  /  \u041C\u041E\u0416\u041D\u041E
      \u0421\u041C\u0415\u041D\u0418\u0422\u042C \u0412 \u041B\u042E\u0411\u041E\u0419
      \u041C\u041E\u041C\u0415\u041D\u0422"
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951403
    m_Localized: "\u041F\u0415\u0420\u0412\u0410\u042F \u042D\u041A\u0421\u041F\u0415\u0414\u0418\u0426\u0418\u042F"
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951404
    m_Localized: "\u0417\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438
      \u0441\u0432\u0435\u0442\u0430 \u043A\u043E\u0441\u0442\u0440\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951405
    m_Localized: "\u041A\u0440\u044B\u0448\u0438 \u0432\u043E\u0437\u0432\u0435\u0434\u0435\u043D\u044B,
      \u043B\u0430\u0433\u0435\u0440\u044F \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442,
      \u043D\u043E \u0437\u0430 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0439
      \u0437\u043D\u0430\u043A\u043E\u043C\u043E\u0439 \u0442\u0440\u043E\u043F\u043E\u0439
      \u0434\u043E\u043B\u0438\u043D\u0430 \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F
      \u043B\u0438\u0448\u044C \u0441\u043B\u0443\u0445\u043E\u043C. \u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435
      \u0432\u0437\u0440\u043E\u0441\u043B\u043E\u0433\u043E, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
      \u043F\u043E\u043D\u0435\u0441\u0451\u0442 \u043D\u0430\u0448\u0443 \u043F\u0435\u0440\u0432\u0443\u044E
      \u043A\u0430\u0440\u0442\u0443 \u0432 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951406
    m_Localized: "\u041D\u0410\u0417\u041D\u0410\u0427\u0418\u0422\u042C \u0420\u0410\u0417\u0412\u0415\u0414\u0427\u0418\u041A\u0410"
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951407
    m_Localized: "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435, \u043A\u0442\u043E
      \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u0441\u044F \u0432 \u043F\u0443\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951408
    m_Localized: "\u041A\u0430\u0436\u0434\u0430\u044F \u043A\u0430\u0440\u0442\u0430
      \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F \u0441 \u0442\u043E\u0433\u043E,
      \u043A\u0442\u043E \u0433\u043E\u0442\u043E\u0432 \u0441\u0432\u0435\u0440\u043D\u0443\u0442\u044C
      \u0441\u043E \u0437\u043D\u0430\u043A\u043E\u043C\u043E\u0439 \u0434\u043E\u0440\u043E\u0433\u0438.
      \u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0432\u0437\u0440\u043E\u0441\u043B\u043E\u0433\u043E,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u043E\u0437\u044C\u043C\u0451\u0442
      \u043A\u043E\u043C\u043F\u0430\u0441 \u043F\u043E\u0441\u0442\u0430 \u0438
      \u043D\u0430\u043D\u0435\u0441\u0451\u0442 \u043D\u0430 \u043A\u0430\u0440\u0442\u0443
      \u0437\u0435\u043C\u043B\u0438 \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438
      \u043F\u043E\u0441\u0435\u043B\u0435\u043D\u0438\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951409
    m_Localized: "\u0421\u041F\u041B\u0410\u041D\u0418\u0420\u041E\u0412\u0410\u0422\u042C
      \u042D\u041A\u0421\u041F\u0415\u0414\u0418\u0426\u0418\u042E"
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951410
    m_Localized: "\u041A\u0430\u043A \u0434\u0430\u043B\u0435\u043A\u043E \u0443\u0439\u0442\u0438
      \u043E\u0442 \u0441\u0432\u0435\u0442\u0430 \u043A\u043E\u0441\u0442\u0440\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951411
    m_Localized: "\u0420\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A \u0433\u043E\u0442\u043E\u0432,
      \u043F\u0443\u0442\u044C \u043E\u0442\u043A\u0440\u044B\u0442. \u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435,
      \u043D\u0430 \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0434\u043D\u0435\u0439
      \u0441\u043E\u0431\u0440\u0430\u0442\u044C \u043F\u0440\u043E\u0432\u0438\u0437\u0438\u044E:
      \u0434\u043E\u043B\u0433\u0430\u044F \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u044F
      \u043D\u0430\u043D\u0435\u0441\u0451\u0442 \u043D\u0430 \u043A\u0430\u0440\u0442\u0443
      \u0431\u043E\u043B\u044C\u0448\u0435 \u0437\u0435\u043C\u0435\u043B\u044C,
      \u043D\u043E \u043A\u0430\u0436\u0434\u044B\u0439 \u0440\u0430\u0441\u0441\u0432\u0435\u0442
      \u0432\u0434\u0430\u043B\u0438 \u043E\u0442 \u043F\u043E\u0441\u0442\u0430
      \u043F\u043E\u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0435\u0449\u0451 \u043E\u0434\u0438\u043D
      \u043F\u0430\u0451\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951412
    m_Localized: "\u0420\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A \u0438\u043B\u0438
      \u043F\u043E\u0441\u0442 \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435
      \u0433\u043E\u0442\u043E\u0432\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951413
    m_Localized: "\u0412\u044B\u0431\u0440\u0430\u043D\u043D\u044B\u0439 \u0436\u0438\u0442\u0435\u043B\u044C
      \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u0435\u043D.
      \u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0434\u0440\u0443\u0433\u043E\u0433\u043E
      \u0440\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951414
    m_Localized: "\u042D\u0442\u043E\u0442 \u0436\u0438\u0442\u0435\u043B\u044C \u0431\u043E\u043B\u044C\u0448\u0435
      \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C\u0441\u044F
      \u0432 \u043F\u0443\u0442\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951415
    m_Localized: "\u041C\u043E\u0436\u043D\u043E \u0432\u044B\u0431\u0440\u0430\u0442\u044C
      \u0434\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951416
    m_Localized: "\u041C\u043E\u0436\u043D\u043E \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0442\u044C\u0441\u044F
      \u0441 \u043F\u0435\u0440\u0432\u043E\u0439 \u043A\u0430\u0440\u0442\u043E\u0439
      \u043F\u043E\u0441\u0435\u043B\u0435\u043D\u0438\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951417
    m_Localized: "\u041C\u043E\u0436\u043D\u043E \u0443\u043D\u0435\u0441\u0442\u0438
      \u043A\u043E\u043C\u043F\u0430\u0441 \u043F\u043E\u0441\u0442\u0430 \u0437\u0430
      \u043F\u0440\u0435\u0434\u0435\u043B\u044B \u0437\u043D\u0430\u043A\u043E\u043C\u044B\u0445
      \u0434\u043E\u0440\u043E\u0433."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951418
    m_Localized: "\u042D\u0442\u043E\u0442 \u0440\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A
      \u0438\u043B\u0438 \u043F\u043E\u0441\u0442 \u0431\u043E\u043B\u044C\u0448\u0435
      \u043D\u0435 \u0433\u043E\u0442\u043E\u0432\u044B \u043A \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044E."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951419
    m_Localized: "\u0412\u044B\u0431\u0440\u0430\u043D\u043D\u044B\u0439 \u0436\u0438\u0442\u0435\u043B\u044C
      \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u0435\u043D.
      \u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0434\u0440\u0443\u0433\u043E\u0433\u043E
      \u0440\u0430\u0437\u0432\u0435\u0434\u0447\u0438\u043A\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951420
    m_Localized: "\u042D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u044F \u043D\u0435
      \u043C\u043E\u0436\u0435\u0442 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C\u0441\u044F
      \u0431\u0435\u0437 \u0432\u0441\u0435\u0445 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u044B\u0445
      \u043F\u0430\u0439\u043A\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 183701936951421
    m_Localized: "\u041D\u0435 \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C
      \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u044E. \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
      \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0441\u044F \u0437\u0430\u043F\u0430\u0441
      \u043F\u0440\u043E\u0432\u0438\u0437\u0438\u0438 \u0438\u043B\u0438 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
      \u043F\u043E\u0441\u0442\u0430."
    m_Metadata:
